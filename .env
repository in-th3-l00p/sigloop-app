# =============================
# Sigloop Unified Environment
# =============================
# This file includes build-time and runtime env vars used across:
# - frontend
# - landing
# - card-service
# - api-service
# - optional examples/integration tests

# -----------------------------
# Required for Production Deploy
# -----------------------------
CONVEX_URL=https://your-convex-deployment.convex.cloud
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud
VITE_PRIVY_APP_ID=your_privy_app_id

# -----------------------------
# Build-Time Routing Settings
# -----------------------------
# Frontend (React) served under /app
FRONTEND_BASE=/app/
# Card service base used by frontend integrations
VITE_CARD_SERVICE_URL=https://card.sigloop.online
VITE_API_SERVICE_URL=https://api.sigloop.online
# Landing (Astro) served at root
LANDING_BASE=/

# -----------------------------
# Runtime Service Settings (Optional Overrides)
# -----------------------------
CARD_SERVICE_PORT=8787
API_SERVICE_PORT=8788
ZERODEV_PROJECT_ID=
SEPOLIA_RPC_URL=https://rpc.sepolia.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
TX_RETRY_WINDOW_MS=120000

# -----------------------------
# Convex/Auth Tooling (Optional)
# -----------------------------
# Used by frontend/convex/auth.config.js when running convex tooling.
PRIVY_APP_ID=your_privy_app_id

# -----------------------------
# Optional Integration Consumer Vars
# -----------------------------
SIGLOOP_API_KEY=
SIGLOOP_CARD_SECRET=
SIGLOOP_CARD_SERVICE_URL=https://card.sigloop.online
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------
# Optional Integration Test Vars
# -----------------------------
RUN_INTEGRATION_TESTS=false
CARD_SERVICE_BASE_URL=https://card.sigloop.online
CARD_SERVICE_TEST_SECRET=
API_SERVICE_BASE_URL=https://api.sigloop.online
API_SERVICE_TEST_KEY=
