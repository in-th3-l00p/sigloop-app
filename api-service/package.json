    "@zerodev/sdk": "^5.5.7",
    "convex": "^1.32.0",
    "hono": "^4.6.12",
    "viem": "^2.46.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
